---
const links = [
  { label: 'Email',    value: 'ujjawalsaini47@gmail.com',       href: 'mailto:ujjawalsaini47@gmail.com' },
  { label: 'GitHub',   value: 'github.com/spignelon',           href: 'https://github.com/spignelon' },
  { label: 'LinkedIn', value: 'linkedin.com/in/spignelon',      href: 'https://www.linkedin.com/in/spignelon' },
  { label: 'Telegram', value: '@spignelon',                     href: 'https://t.me/spignelon' },
  { label: 'Twitter',  value: '@spignelon',                     href: 'https://twitter.com/spignelon' },
  { label: 'Writing',  value: 'spignelon.github.io/blog',        href: '/blog' },
  { label: 'Discord',  value: 'spignelon',                      href: '#' },
];
---

<section id="contact" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">Contact</p>

  <div class="max-w-5xl grid lg:grid-cols-[2fr_1fr] gap-12">

    <!-- Left: copy + primary CTA -->
    <div>
      <p class="text-zinc-400 text-sm leading-relaxed max-w-sm mb-8">
        Open to new roles, freelance projects, and collaboration.
        If you have something interesting in mind, reach out — I respond to everything.
      </p>

      <a
        href="mailto:ujjawalsaini47@gmail.com"
        class="inline-flex items-center gap-3 text-sm font-mono text-violet-400 border border-violet-800/50
               px-5 py-3 hover:bg-violet-950/40 transition-colors duration-150"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        ujjawalsaini47@gmail.com
      </a>
    </div>

    <!-- Right: link list -->
    <div class="divide-y divide-zinc-800/40">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.href.startsWith('http') ? '_blank' : undefined}
          rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="group flex items-center justify-between py-3"
        >
          <span class="font-mono text-[11px] text-zinc-700 uppercase tracking-wider w-20">{l.label}</span>
          <span class="text-zinc-500 text-xs font-mono group-hover:text-violet-400 transition-colors truncate max-w-[160px]">
            {l.value}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
