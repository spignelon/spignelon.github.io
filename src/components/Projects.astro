---
// Featured: shown as horizontal editorial strips with image
const featured = [
  {
    num: '01',
    title: 'NearBy',
    description:
      'A hyper-local, anonymous, interest-based PWA chat app. No accounts, no profiles — users connect with people nearby who share their interests via real-time WebSocket communication and PostGIS location matching.',
    image: null,
    tags: ['Django', 'Django Channels', 'React', 'PWA', 'PostGIS', 'Redis'],
    github: 'https://github.com/spignelon',
    award: null,
    featured: true,
  },
  {
    num: '02',
    title: 'Social2Amazon',
    description:
      'AI pipeline that scrapes Instagram, TikTok, and Facebook content and converts it into structured Amazon product listings using LLMs. Auto-publishes to Amazon via SP-API with a management dashboard.',
    image: '/images/social2amazon.png',
    tags: ['Django', 'React.js', 'LLMs', 'BeautifulSoup', 'Selenium', 'Amazon SP-API'],
    github: 'https://github.com/spignelon',
    award: '🏆 1st Runner-Up — Amazon Sambhav Hackathon 2024',
  },
  {
    num: '03',
    title: 'TorBreaker',
    description:
      '15+ custom Python modules for detecting misconfigured Tor onion sites: automated URL crawling, misconfiguration scanning, and AI-driven legality classification. Built at Smart India Hackathon 2024.',
    image: '/images/torBreaker.png',
    tags: ['Django', 'Celery', 'Redis', 'MongoDB', 'Cybersecurity'],
    github: 'https://github.com/spignelon',
    award: '🛡 Smart India Hackathon 2024',
  },
];

// Other: compact table rows
const others = [
  {
    title: 'WaitBin',
    description: 'Time-locked pastebin — content stays hidden until a specific date. Live countdown, shareable links.',
    tags: ['Flask', 'MongoDB', 'Tailwind'],
    image: '/images/WaitBin.png',
  },
  {
    title: 'NoLlama',
    description: 'Terminal chat client for Gemini 2.0 Flash / 2.5 Pro. Streaming, model switching, markdown rendering.',
    tags: ['Python', 'Gemini API', 'Terminal UI'],
    image: '/images/NoLlama.png',
  },
  {
    title: 'Facemap',
    description: '99.2% accuracy face-recognition photo sharing platform. Custom metadata stripping modules.',
    tags: ['Django', 'FaceNet', 'PostgreSQL'],
    image: '/images/facemap.png',
    award: '🥈 HackEDCode 2.0',
  },
  {
    title: 'ML Text Analyzer',
    description: 'NLP pipeline for multi-class classification and sentiment analysis with a Flask API layer.',
    tags: ['Python', 'TensorFlow', 'Flask'],
    image: null,
  },
  {
    title: 'Secure API Gateway',
    description: 'JWT auth, per-client rate limiting, and transparent proxying in a single Golang binary.',
    tags: ['Golang', 'Redis', 'Docker'],
    image: null,
  },
];
---

<section id="projects" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">Projects</p>

  <!-- ── FEATURED: horizontal editorial strips ── -->
  <div class="max-w-5xl space-y-0 divide-y divide-zinc-800/40 mb-16">
    {featured.map((p) => (
      <div class="group grid md:grid-cols-[auto_1fr] gap-0 py-8 first:pt-0">

        <!-- Image / placeholder column -->
        <div class="hidden md:block w-56 h-36 overflow-hidden mr-8 flex-shrink-0 border border-zinc-800/60 bg-zinc-900">
          {p.image ? (
            <img
              src={p.image}
              alt={p.title}
              class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-violet-950/40 to-zinc-900">
              <span class="text-3xl font-bold font-mono text-zinc-800 select-none">{p.num}</span>
            </div>
          )}
        </div>

        <!-- Content column -->
        <div>
          <div class="flex items-baseline gap-3 mb-2">
            <span class="font-mono text-[11px] text-zinc-700">{p.num}</span>
            <h3 class="text-zinc-100 font-semibold text-base group-hover:text-violet-300 transition-colors">
              {p.title}
            </h3>
            {p.featured && (
              <span class="text-[10px] font-mono text-violet-600 border border-violet-800/50 px-1.5 py-0.5">
                featured
              </span>
            )}
          </div>

          {p.award && (
            <p class="text-[11px] font-mono text-amber-500/70 mb-2">{p.award}</p>
          )}

          <p class="text-zinc-500 text-sm leading-relaxed mb-3 max-w-lg">{p.description}</p>

          <div class="flex flex-wrap gap-1.5 mb-3">
            {p.tags.map((t) => <span class="chip">{t}</span>)}
          </div>

          <a
            href={p.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[11px] font-mono text-zinc-700 hover:text-violet-400 transition-colors"
          >
            github.com/spignelon ↗
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- ── OTHERS: compact table ── -->
  <div class="max-w-5xl">
    <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-zinc-800 mb-4">More Projects</p>

    <div class="divide-y divide-zinc-800/30">
      {others.map((p) => (
        <div class="group py-4 grid sm:grid-cols-[1fr_auto] gap-4 items-start">
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h4 class="text-zinc-300 text-sm font-medium group-hover:text-violet-300 transition-colors">
                {p.title}
              </h4>
              {p.award && (
                <span class="text-[10px] font-mono text-amber-600/70">{p.award}</span>
              )}
            </div>
            <p class="text-zinc-600 text-xs leading-relaxed">{p.description}</p>
          </div>
          <div class="flex flex-wrap gap-1 sm:justify-end">
            {p.tags.map((t) => <span class="chip">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
