---
const experiences = [
  {
    role: 'Backend Developer Intern',
    company: 'Mudraksh & McShaw Tech LLP',
    period: 'Mar – Jul 2025',
    bullets: [
      'Improved WorkSage backend: task tagging, analytics dashboard, employee tracking.',
      'Built Trade Compass — P&L engine using Flask, Pandas, and TrueData.in API.',
      'Accelerated MVP cycles by integrating Agentic AI tooling into the engineering workflow.',
    ],
  },
  {
    role: 'Summer Intern',
    company: 'IBM — SkillsBuild × CSRBOX',
    period: 'Jul – Aug 2024',
    bullets: [
      'AI/ML application development with IBM SkillsBuild and CSRBOX.',
      'Applied enterprise-standard methodologies and toolchains.',
    ],
  },
  {
    role: 'Backend Consultant & Business Adviser',
    company: 'Repairo Tech',
    period: 'Sep 2022 – Dec 2024',
    bullets: [
      'Ported full Laravel PHP backend to Python Django — improved maintainability significantly.',
      'Resolved critical backend issues and advised on service architecture decisions.',
    ],
  },
  {
    role: 'Open Source Contributor',
    company: 'Social Summer of Code (Script Foundation)',
    period: 'Jun – Aug 2024',
    bullets: [
      'Contributed to open-source projects under the SSoC programme.',
      'Version control, collaborative code review, and engineering best practices at scale.',
    ],
  },
];
---

<section id="experience" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">Experience</p>

  <div class="max-w-5xl">
    <!-- Table header -->
    <div class="hidden sm:grid grid-cols-[1fr_auto] gap-8 pb-2 border-b border-zinc-800/50
                text-[10px] font-mono uppercase tracking-[0.2em] text-zinc-700">
      <span>Role / Company</span>
      <span class="text-right">Period</span>
    </div>

    <!-- Entries -->
    <div class="divide-y divide-zinc-800/40">
      {experiences.map((exp) => (
        <div class="py-7 group">
          <!-- Header row -->
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <div>
              <span class="text-zinc-100 font-medium text-sm">{exp.role}</span>
              <span class="mx-2 text-zinc-700 text-xs">at</span>
              <span class="text-violet-400 font-mono text-xs">{exp.company}</span>
            </div>
            <span class="font-mono text-[11px] text-zinc-700 whitespace-nowrap">{exp.period}</span>
          </div>

          <!-- Bullet points -->
          <ul class="space-y-1.5 pl-0">
            {exp.bullets.map((b) => (
              <li class="flex gap-3 text-xs text-zinc-600 leading-relaxed">
                <span class="text-zinc-800 flex-shrink-0 select-none">—</span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
