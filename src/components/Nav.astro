<!-- ═══════════════════════ MOBILE TOP BAR ═══════════════════════ -->
<div class="lg:hidden fixed top-0 inset-x-0 z-50 h-14 flex items-center justify-between px-5
            bg-zinc-950/90 backdrop-blur-md border-b border-zinc-800/60">
  <a href="/" class="text-zinc-100 font-semibold text-sm font-mono">Ujjawal Saini</a>

  <button
    id="mob-toggle"
    aria-label="Toggle menu"
    aria-expanded="false"
    class="flex flex-col gap-[5px] p-1.5"
  >
    <span class="mob-bar w-5 h-px bg-zinc-400 transition-all duration-200 origin-center"></span>
    <span class="mob-bar w-5 h-px bg-zinc-400 transition-all duration-200"></span>
    <span class="mob-bar w-5 h-px bg-zinc-400 transition-all duration-200 origin-center"></span>
  </button>
</div>

<!-- Mobile full-screen drawer -->
<div
  id="mob-menu"
  class="hidden lg:hidden fixed inset-0 z-40 bg-zinc-950 pt-14 flex flex-col"
>
  <nav class="flex-1 flex flex-col justify-center px-8 space-y-1">
    <a href="/#intro"        class="mob-link">Overview</a>
    <a href="/#about"        class="mob-link">About</a>
    <a href="/#experience"   class="mob-link">Experience</a>
    <a href="/#projects"     class="mob-link">Projects</a>
    <a href="/#skills"       class="mob-link">Skills</a>
    <a href="/#achievements" class="mob-link">Awards</a>
    <a href="/#contact"      class="mob-link">Contact</a>
    <a href="/blog"         class="mob-link">Writing</a>
  </nav>
  <div class="px-8 py-8 border-t border-zinc-800/40">
    <a href="/resume.pdf" target="_blank" rel="noopener noreferrer"
       class="text-sm font-mono text-violet-400">Resume ↗</a>
  </div>
</div>

<style>
  .mob-link {
    @apply text-2xl font-semibold text-zinc-500 hover:text-zinc-100 transition-colors py-2;
  }
</style>

<script>
  const toggle = document.getElementById('mob-toggle')!;
  const menu   = document.getElementById('mob-menu')!;
  const bars   = document.querySelectorAll<HTMLElement>('.mob-bar');
  let open = false;

  toggle.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';

    bars[0].style.transform = open ? 'rotate(45deg) translateY(6px)'  : '';
    bars[1].style.opacity   = open ? '0' : '1';
    bars[2].style.transform = open ? 'rotate(-45deg) translateY(-6px)' : '';
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      bars[0].style.transform = bars[1].style.opacity = bars[2].style.transform = '';
      bars[1].style.opacity = '1';
    });
  });
</script>
