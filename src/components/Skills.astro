---
const categories = [
  { name: 'Languages',    items: ['Python', 'Golang', 'Java', 'C/C++', 'JavaScript', 'Shell / Bash'] },
  { name: 'Frameworks',  items: ['Django', 'Flask', 'FastAPI', 'Django REST Framework', 'Celery'] },
  { name: 'ML / AI',     items: ['TensorFlow', 'PyTorch', 'scikit-learn', 'Hugging Face', 'FastAI', 'NumPy', 'Pandas'] },
  { name: 'Databases',   items: ['PostgreSQL', 'MongoDB', 'Redis', 'MySQL', 'SQLite', 'MariaDB'] },
  { name: 'DevOps',      items: ['Docker', 'Linux', 'Git', 'GitHub Actions', 'Nginx', 'SSH', 'Vim'] },
  { name: 'Focus Areas', items: ['Backend Architecture', 'Generative AI', 'Cyber Security', 'System Admin', 'DevOps'] },
];
---

<section id="skills" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">Skills</p>

  <div class="max-w-5xl">
    <!-- Definition-list style — two column on desktop -->
    <div class="divide-y divide-zinc-800/40">
      {categories.map((cat) => (
        <div class="py-4 grid grid-cols-1 sm:grid-cols-[120px_1fr] gap-2 sm:gap-8 items-baseline">
          <span class="font-mono text-[11px] text-zinc-700 uppercase tracking-wider pt-0.5 flex-shrink-0">
            {cat.name}
          </span>
          <span class="text-zinc-500 text-sm leading-relaxed">
            {cat.items.join(' · ')}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
