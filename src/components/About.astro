<section id="about" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">About</p>

  <div class="grid lg:grid-cols-[2fr_1fr] gap-12 max-w-5xl">

    <!-- Bio -->
    <div class="space-y-4 text-zinc-400 text-sm leading-relaxed">
      <p>
        I'm Ujjawal — a B.Tech student in AI & Machine Learning at
        <span class="text-zinc-300">Guru Gobind Singh Indraprastha University</span>,
        graduating 2025. I build reliable backend infrastructure and intelligent
        applications that turn messy data into working systems.
      </p>
      <p>
        My work is shaped by <span class="text-zinc-300">precision and follow-through</span>.
        I've won multiple national hackathons —
        <span class="text-violet-400">Amazon Sambhav 2024</span> (1st Runner-Up) and
        <span class="text-violet-400">Intel GenAI Hackathon at IIT Delhi</span> (1st Rank) —
        shipping production-ready code under competitive pressure.
      </p>
      <p>
        Professionally, I've worked as a Backend Developer Intern at
        <span class="text-zinc-300">Mudraksh & McShaw Tech LLP</span>,
        interned at <span class="text-zinc-300">IBM SkillsBuild</span>,
        and served as Backend Consultant at <span class="text-zinc-300">Repairo Tech</span>
        — where I ported an entire Laravel codebase to Python Django.
      </p>
      <p>
        Outside of work: LeetCode (rating
        <span class="text-violet-400 font-mono">1753</span>, top 9.67%),
        open-source contributions, and Stoic philosophy.
      </p>
    </div>

    <!-- Stats + Education -->
    <div class="space-y-6">

      <!-- Quick stats — minimal grid -->
      <div class="grid grid-cols-2 gap-px bg-zinc-800/50 border border-zinc-800/50">
        <div class="bg-zinc-950 p-4">
          <p class="text-2xl font-bold text-zinc-100 font-mono">7+</p>
          <p class="text-[11px] text-zinc-600 mt-0.5 uppercase tracking-wider">Hackathons</p>
        </div>
        <div class="bg-zinc-950 p-4">
          <p class="text-2xl font-bold text-zinc-100 font-mono">1753</p>
          <p class="text-[11px] text-zinc-600 mt-0.5 uppercase tracking-wider">LeetCode</p>
        </div>
        <div class="bg-zinc-950 p-4">
          <p class="text-2xl font-bold text-zinc-100 font-mono">Top 10%</p>
          <p class="text-[11px] text-zinc-600 mt-0.5 uppercase tracking-wider">DevRank</p>
        </div>
        <div class="bg-zinc-950 p-4">
          <p class="text-2xl font-bold text-zinc-100 font-mono">4y</p>
          <p class="text-[11px] text-zinc-600 mt-0.5 uppercase tracking-wider">Experience</p>
        </div>
      </div>

      <!-- Education -->
      <div class="border border-zinc-800/60 p-4">
        <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-zinc-700 mb-3">Education</p>
        <p class="text-zinc-200 font-medium text-sm">B.Tech — AI & Machine Learning</p>
        <p class="text-zinc-600 text-xs font-mono mt-1">GGSIPU, New Delhi</p>
        <div class="flex justify-between items-center mt-3 pt-3 border-t border-zinc-800/50">
          <span class="font-mono text-[11px] text-zinc-700">2021 – 2025</span>
          <span class="chip">CGPA 7.9</span>
        </div>
      </div>
    </div>
  </div>
</section>
