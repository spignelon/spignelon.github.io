---
const hackathons = [
  { title: '1st Runner-Up', event: 'Amazon Sambhav Hackathon 2024', scope: 'National' },
  { title: '1st Rank', event: 'Intel GenAI Hackathon at IIT Delhi', scope: 'National' },
  { title: 'Winner', event: 'International Intel × Red Hat AI Hackathon', scope: 'International' },
  { title: 'P.S. Winner', event: 'CodeUtsav 8.0 at NIT Raipur', scope: 'National' },
  { title: '2nd Rank', event: 'hackEDCode 2.0 at GGSIPU', scope: 'University' },
  { title: '3rd Rank', event: 'HackDUCS at Delhi University', scope: 'Inter-University' },
];
---

<section id="achievements" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <div>
        <span class="section-number">05.</span>
        <h2 class="section-heading">Achievements</h2>
      </div>
      <div class="hidden sm:block flex-1 h-px bg-slate-800 ml-4 max-w-xs"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <!-- LeetCode -->
      <div class="card card-hover p-6 rounded-xl">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-lg bg-orange-500/10 border border-orange-500/20 flex items-center justify-center flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-orange-400"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.378 1.378 0 0 0-1.951-.003l-2.396 2.392a3.021 3.021 0 0 1-4.205.038l-.02-.019-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.68 2.68 0 0 1 .066-.523 2.545 2.545 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l3.501 2.831c.593.48 1.461.387 1.94-.207a1.384 1.384 0 0 0-.207-1.943l-3.5-2.831c-.8-.647-1.766-1.045-2.774-1.202l2.015-2.158A1.384 1.384 0 0 0 13.483 0zm-2.866 12.815a1.38 1.38 0 0 0-1.38 1.382 1.38 1.38 0 0 0 1.38 1.382H20.79a1.38 1.38 0 0 0 1.38-1.382 1.38 1.38 0 0 0-1.38-1.382z" />
            </svg>
          </div>
          <div>
            <h3 class="text-slate-100 font-semibold">LeetCode</h3>
            <p class="text-xs text-slate-600 font-mono">Competitive Programming</p>
          </div>
        </div>
        <div class="mb-5">
          <p class="text-4xl font-bold text-orange-400 font-mono">1753</p>
          <p class="text-slate-500 text-sm mt-1">Contest Rating</p>
        </div>
        <div class="h-px bg-slate-800 mb-4"></div>
        <p class="text-slate-500 text-sm leading-relaxed mb-4">
          Top <span class="text-slate-300 font-semibold">9.67%</span> globally. Consistent
          performance in timed contests with strong algorithmic and data structure foundations.
        </p>
        <a
          href="https://leetcode.com/u/spignelon/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-slate-600 hover:text-orange-400 transition-colors"
        >
          leetcode.com/u/spignelon ↗
        </a>
      </div>

      <!-- Quine DevRank -->
      <div class="card card-hover p-6 rounded-xl">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-purple-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <div>
            <h3 class="text-slate-100 font-semibold">Quine DevRank</h3>
            <p class="text-xs text-slate-600 font-mono">Code Quality</p>
          </div>
        </div>
        <div class="mb-5">
          <p class="text-4xl font-bold text-purple-400 font-mono">Top 10%</p>
          <p class="text-slate-500 text-sm mt-1">Global Developer Rank</p>
        </div>
        <div class="h-px bg-slate-800 mb-4"></div>
        <p class="text-slate-500 text-sm leading-relaxed mb-4">
          Recognized for writing clean, efficient, and maintainable code across public repositories.
          Strong software engineering principles with consistent open-source contributions.
        </p>
        <a
          href="https://quine.sh/user/spignelon"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-slate-600 hover:text-purple-400 transition-colors"
        >
          quine.sh/user/spignelon ↗
        </a>
      </div>

      <!-- Hackathons -->
      <div class="card card-hover p-6 rounded-xl">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-lg bg-amber-500/10 border border-amber-500/20 flex items-center justify-center flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-amber-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
              <path d="M4 22h16"></path>
              <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-slate-100 font-semibold">Hackathons</h3>
            <p class="text-xs text-slate-600 font-mono">7+ wins</p>
          </div>
        </div>
        <ul class="space-y-3">
          {
            hackathons.map((h) => (
              <li class="flex items-start gap-2.5">
                <span class="text-amber-400 text-xs mt-0.5 flex-shrink-0">▸</span>
                <div class="text-sm">
                  <span class="text-slate-200 font-medium">{h.title}</span>
                  <span class="text-slate-500"> — {h.event}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
