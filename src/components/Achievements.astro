---
const wins = [
  { rank: '1st Runner-Up', event: 'Amazon Sambhav Hackathon 2024',       scope: 'National' },
  { rank: '1st Rank',      event: 'Intel GenAI Hackathon @ IIT Delhi',   scope: 'National' },
  { rank: 'Winner',        event: 'Intel × Red Hat AI Hackathon',        scope: 'International' },
  { rank: 'P.S. Winner',   event: 'CodeUtsav 8.0 @ NIT Raipur',         scope: 'National' },
  { rank: '2nd Rank',      event: 'hackEDCode 2.0 @ GGSIPU',            scope: 'University' },
  { rank: '3rd Rank',      event: 'HackDUCS @ Delhi University',         scope: 'Inter-University' },
];
---

<section id="achievements" class="px-6 lg:px-12 py-16 border-t border-zinc-800/50">
  <p class="section-label">Awards & Recognition</p>

  <div class="max-w-5xl">

    <!-- Stat strip -->
    <div class="grid grid-cols-3 divide-x divide-zinc-800/50 border border-zinc-800/50 mb-12">
      <div class="px-6 py-5">
        <p class="text-2xl font-bold text-zinc-100 font-mono">1753</p>
        <p class="text-[11px] font-mono text-zinc-700 mt-1 uppercase tracking-wider">LeetCode Rating</p>
        <p class="text-xs text-zinc-600 mt-0.5">Top 9.67% globally</p>
      </div>
      <div class="px-6 py-5">
        <p class="text-2xl font-bold text-zinc-100 font-mono">Top 10%</p>
        <p class="text-[11px] font-mono text-zinc-700 mt-1 uppercase tracking-wider">Quine DevRank</p>
        <p class="text-xs text-zinc-600 mt-0.5">Global code quality rank</p>
      </div>
      <div class="px-6 py-5">
        <p class="text-2xl font-bold text-zinc-100 font-mono">7+</p>
        <p class="text-[11px] font-mono text-zinc-700 mt-1 uppercase tracking-wider">Hackathons Won</p>
        <p class="text-xs text-zinc-600 mt-0.5">National & international</p>
      </div>
    </div>

    <!-- Wins list -->
    <div class="divide-y divide-zinc-800/30">
      {wins.map((w) => (
        <div class="py-3.5 grid grid-cols-[auto_1fr_auto] gap-6 items-center">
          <span class="font-mono text-xs text-violet-400 w-28 flex-shrink-0">{w.rank}</span>
          <span class="text-zinc-400 text-sm">{w.event}</span>
          <span class="text-[10px] font-mono text-zinc-700 text-right">{w.scope}</span>
        </div>
      ))}
    </div>

    <!-- External profile links -->
    <div class="flex gap-6 mt-8 pt-6 border-t border-zinc-800/30">
      <a href="https://leetcode.com/u/spignelon/" target="_blank" rel="noopener noreferrer"
         class="text-xs font-mono text-zinc-700 hover:text-violet-400 transition-colors">
        LeetCode ↗
      </a>
      <a href="https://quine.sh/user/spignelon" target="_blank" rel="noopener noreferrer"
         class="text-xs font-mono text-zinc-700 hover:text-violet-400 transition-colors">
        Quine ↗
      </a>
    </div>
  </div>
</section>
