---

<!--
  Replaces the old "Hi my name is + code block" hero.
  Left: large stacked name + descriptor line + two CTAs
  Right: terminal-style status readout (no code block)
-->
<section
  id="intro"
  class="min-h-[calc(100vh-0px)] flex flex-col justify-center
         px-6 lg:px-12 pt-20 lg:pt-0 pb-16"
>
  <div class="max-w-5xl w-full">
    <div class="grid lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-center">

      <!-- ── LEFT: Identity ── -->
      <div class="animate-fade-up">
        <!-- Role breadcrumb -->
        <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-700 mb-6">
          Backend · Generative AI · Data Science
        </p>

        <!-- Name — very large, tight -->
        <h1 class="text-[clamp(3rem,8vw,5.5rem)] font-bold text-zinc-100 leading-[0.95] tracking-tight mb-6">
          Ujjawal<br />Saini
        </h1>

        <!-- Single-line role statement -->
        <p class="text-zinc-500 text-base leading-relaxed max-w-sm mb-10">
          Associate Engineer building reliable backend systems and
          intelligent AI pipelines. B.Tech AIML @ GGSIPU.
          Hackathon winner. Open-source contributor.
        </p>

        <!-- CTAs — flat, not rounded -->
        <div class="flex flex-wrap gap-3">
          <a
            href="#projects"
            class="px-5 py-2.5 text-sm font-medium bg-violet-600 text-white
                   hover:bg-violet-500 transition-colors duration-150"
          >
            View Projects
          </a>
          <a
            href="#contact"
            class="px-5 py-2.5 text-sm font-medium border border-zinc-700 text-zinc-400
                   hover:border-violet-600/60 hover:text-violet-300 transition-colors duration-150"
          >
            Get In Touch
          </a>
          <a
            href="/blog"
            class="px-5 py-2.5 text-sm font-medium text-zinc-600
                   hover:text-zinc-300 transition-colors duration-150"
          >
            Writing →
          </a>
        </div>
      </div>

      <!-- ── RIGHT: Terminal status readout ── -->
      <div class="hidden lg:block w-72 border border-zinc-800 bg-zinc-900/40 font-mono text-xs">
        <!-- Window bar -->
        <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-zinc-800 bg-zinc-900/60">
          <span class="w-2 h-2 rounded-full bg-zinc-800"></span>
          <span class="w-2 h-2 rounded-full bg-zinc-800"></span>
          <span class="w-2 h-2 rounded-full bg-zinc-800"></span>
          <span class="ml-2 text-zinc-700">status.sh</span>
        </div>

        <!-- Terminal output -->
        <div class="p-5 space-y-1 text-zinc-600 leading-relaxed">
          <p><span class="text-zinc-700">$</span> <span class="text-violet-400">whoami</span></p>
          <p class="text-zinc-300 pl-2">ujjawal_saini</p>

          <p class="pt-2"><span class="text-zinc-700">$</span> <span class="text-violet-400">status</span></p>
          <p class="pl-2">
            <span class="text-zinc-700 inline-block w-16">role</span>
            <span class="text-zinc-400">associate_engineer</span>
          </p>
          <p class="pl-2">
            <span class="text-zinc-700 inline-block w-16">focus</span>
            <span class="text-zinc-400">backend, gen_ai</span>
          </p>
          <p class="pl-2">
            <span class="text-zinc-700 inline-block w-16">location</span>
            <span class="text-zinc-400">new_delhi, IN</span>
          </p>
          <p class="pl-2">
            <span class="text-zinc-700 inline-block w-16">open_to</span>
            <span class="text-emerald-400">opportunities</span>
          </p>

          <p class="pt-2"><span class="text-zinc-700">$</span> <span class="text-violet-400">highlights</span></p>
          <p class="pl-2 text-zinc-600">→ Amazon Sambhav · 1st Runner-Up</p>
          <p class="pl-2 text-zinc-600">→ Intel GenAI @ IIT Delhi · 1st</p>
          <p class="pl-2 text-zinc-600">→ LeetCode 1753 · top 9.67%</p>
          <p class="pl-2 text-zinc-600">→ 7+ hackathons won</p>

          <p class="pt-3 flex items-center gap-1 text-zinc-700">
            <span>$</span>
            <span class="inline-block w-2 h-3.5 bg-violet-500/60 animate-blink"></span>
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
