---
---

<section id="hero" class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Ambient background glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 left-1/4 w-80 h-80 bg-cyan-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 py-24 w-full grid lg:grid-cols-2 gap-16 items-center">
    <!-- Left: Copy -->
    <div class="animate-fade-in">
      <p class="font-mono text-cyan-400 text-sm mb-4 tracking-wide">Hi, my name is</p>

      <h1 class="text-5xl lg:text-6xl font-bold text-slate-100 leading-tight mb-3">
        Ujjawal Saini.
      </h1>
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-500 leading-tight mb-6">
        I build intelligent systems.
      </h2>

      <p class="text-slate-400 text-lg leading-relaxed mb-10 max-w-lg">
        Associate Engineer specializing in
        <span class="text-slate-200">Backend Architecture</span>,
        <span class="text-slate-200">Generative AI pipelines</span>, and
        <span class="text-slate-200">Data Science</span>.
        B.Tech AIML @ GGSIPU · Hackathon winner · Open-source contributor.
      </p>

      <div class="flex flex-wrap gap-4 mb-12">
        <a
          href="#projects"
          class="px-6 py-3 bg-cyan-500 text-slate-950 font-semibold rounded-lg hover:bg-cyan-400 transition-colors duration-150"
        >
          View Projects
        </a>
        <a
          href="#contact"
          class="px-6 py-3 border border-slate-700 text-slate-300 rounded-lg hover:border-cyan-500/50 hover:text-cyan-400 transition-colors duration-150"
        >
          Get In Touch
        </a>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-5">
        <a href="https://github.com/spignelon" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/spignelon" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://t.me/spignelon" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Telegram">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
        <a href="https://ujjawalsaini.hashnode.dev/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Hashnode Blog">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 337 337" fill="currentColor">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M168.5 0C75.42 0 0 75.42 0 168.5S75.42 337 168.5 337 337 261.58 337 168.5 261.58 0 168.5 0zm-7.6 105.08a1 1 0 0 1 1 0l47.37 27.35a1 1 0 0 1 .5.86v54.7a1 1 0 0 1-.5.87l-47.37 27.35a1 1 0 0 1-1 0l-47.36-27.35a1 1 0 0 1-.5-.87v-54.7a1 1 0 0 1 .5-.86l47.36-27.35z"/>
          </svg>
        </a>
        <a href="mailto:ujjawalsaini47@gmail.com" class="social-link" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Right: Code block -->
    <div class="hidden lg:block animate-slide-up">
      <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden shadow-2xl shadow-black/40">
        <!-- Window chrome -->
        <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/60 border-b border-slate-800">
          <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
          <span class="ml-3 text-xs font-mono text-slate-500">ujjawal.py</span>
        </div>
        <!-- Syntax-highlighted code -->
        <pre class="p-6 text-sm leading-7 font-mono overflow-x-auto text-slate-300"><code><span class="text-purple-400">class</span> <span class="text-cyan-300">UjjawalSaini</span>:
    <span class="text-slate-500">"""Associate Engineer | Backend & GenAI"""</span>

    <span class="text-purple-400">def</span> <span class="text-blue-300">__init__</span>(<span class="text-orange-300">self</span>):
        <span class="text-orange-300">self</span>.role    = <span class="text-green-400">"Associate Engineer"</span>
        <span class="text-orange-300">self</span>.location = <span class="text-green-400">"New Delhi, India"</span>
        <span class="text-orange-300">self</span>.stack = &#123;
            <span class="text-green-400">"languages"</span>: [<span class="text-green-400">"Python"</span>, <span class="text-green-400">"Go"</span>, <span class="text-green-400">"Java"</span>],
            <span class="text-green-400">"backend"</span>:   [<span class="text-green-400">"Django"</span>, <span class="text-green-400">"Flask"</span>, <span class="text-green-400">"FastAPI"</span>],
            <span class="text-green-400">"infra"</span>:     [<span class="text-green-400">"Docker"</span>, <span class="text-green-400">"Linux"</span>, <span class="text-green-400">"PostgreSQL"</span>],
        &#125;

    <span class="text-purple-400">def</span> <span class="text-blue-300">interests</span>(<span class="text-orange-300">self</span>) -&gt; <span class="text-cyan-300">list</span>[<span class="text-cyan-300">str</span>]:
        <span class="text-purple-400">return</span> [
            <span class="text-green-400">"Generative AI Pipelines"</span>,
            <span class="text-green-400">"Backend Architecture"</span>,
            <span class="text-green-400">"Data Science"</span>,
            <span class="text-green-400">"Cyber Security"</span>,
        ]

    <span class="text-purple-400">def</span> <span class="text-blue-300">current_focus</span>(<span class="text-orange-300">self</span>) -&gt; <span class="text-cyan-300">str</span>:
        <span class="text-purple-400">return</span> <span class="text-green-400">"Building AI-powered systems"</span></code></pre>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <a href="#about" class="text-slate-700 hover:text-cyan-500 transition-colors animate-bounce block" aria-label="Scroll down">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </a>
  </div>
</section>
