---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Ujjawal Saini">
  <div class="min-h-screen flex items-center px-6 lg:px-12">
    <div>
      <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-zinc-700 mb-4">404</p>
      <h1 class="text-4xl font-bold text-zinc-100 mb-3">Page not found.</h1>
      <p class="text-zinc-600 text-sm mb-8 max-w-xs leading-relaxed">
        This URL doesn't exist or has been moved.
      </p>
      <a href="/"
         class="inline-flex items-center gap-2 text-sm font-mono text-violet-400
                border border-violet-800/50 px-4 py-2 hover:bg-violet-950/40 transition-colors">
        ← Go home
      </a>
    </div>
  </div>
</BaseLayout>
