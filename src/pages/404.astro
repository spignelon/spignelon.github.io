---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="font-mono text-cyan-400/60 text-8xl font-bold mb-4 select-none">404</p>
      <h1 class="text-3xl font-bold text-slate-100 mb-4">Page not found.</h1>
      <p class="text-slate-500 mb-10 max-w-sm mx-auto leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-cyan-500 text-slate-950 font-semibold rounded-lg hover:bg-cyan-400 transition-colors"
      >
        Go Home
      </a>
    </div>
  </div>
</BaseLayout>
