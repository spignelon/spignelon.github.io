---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Writing — Ujjawal Saini"
  description="Thoughts on backend architecture, generative AI, and software engineering."
>
  <div class="px-6 lg:px-12 pt-24 lg:pt-16 pb-24 max-w-4xl">

    <a href="/" class="inline-flex items-center gap-2 font-mono text-xs text-zinc-700
                       hover:text-violet-400 transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      home
    </a>

    <p class="section-label">Writing</p>
    <p class="text-zinc-600 text-sm mb-12 max-w-sm leading-relaxed">
      Thoughts on backend architecture, generative AI, and engineering craft.
    </p>

    {posts.length === 0 ? (
      <p class="font-mono text-xs text-zinc-800">No posts yet.</p>
    ) : (
      <div class="divide-y divide-zinc-800/40">
        {posts.map((post) => {
          const d = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}`}
               class="group block py-7 hover:pl-2 transition-all duration-150">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-2">
                <h2 class="text-zinc-200 font-medium text-sm group-hover:text-violet-300 transition-colors">
                  {post.data.title}
                </h2>
                <time class="font-mono text-[11px] text-zinc-700 whitespace-nowrap"
                      datetime={post.data.pubDate.toISOString()}>{d}</time>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed mb-3">{post.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags.map((t) => <span class="chip">{t}</span>)}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
  <Footer />
</BaseLayout>
